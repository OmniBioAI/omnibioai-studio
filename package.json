{
  "name": "omnibioai-studio",
  "version": "0.2.0",
  "productName": "OmniBioAI Studio",
  "description": "AI-powered bioinformatics orchestration desktop platform",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run vite\" \"electron . --no-sandbox\"",
    "vite": "vite",
    "build:ui": "vite build",
    "build:linux": "npm run build:ui && electron-builder --linux",
    "build:mac": "npm run build:ui && electron-builder --mac",
    "build:all": "npm run build:ui && electron-builder --linux --mac",
    "build": "npm run build:linux",
    "dist": "npm run build",
    "web": "vite",
    "web:build": "vite build",
    "web:preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "vite": "^5.0.0"
  },
  "author": "Manish Kumar <mandecent.gupta@gmail.com>"
}
