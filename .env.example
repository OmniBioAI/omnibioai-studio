# OmniBioAI Studio — copy this to .env and fill in your values

# Network
HOST_IP=0.0.0.0

# Paths (set these to your machine paths)
MACHINE_DIR=/path/to/your/machine/dir
WORKSPACE_HOST=${MACHINE_DIR}/omnibioai
WORK_DIR=${MACHINE_DIR}/omnibioai
DATA_DIR=${MACHINE_DIR}/data
DB_INIT_DIR=${MACHINE_DIR}/db-init
VIDEO_DIR=${MACHINE_DIR}/omnibioai-videos/content

# Database
MYSQL_ROOT_PASSWORD=change-me

# Auth
AUTH_SECRET_KEY=change-me-in-production

# LIMS
LIMS_USERNAME=admin
LIMS_PASSWORD=change-me
LIMS_REFRESH_TOKEN=

# API Keys (optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
RAGBIO_API_KEY=

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# License
LICENSE_SECRET=change-me-in-production
GHCR_PULL_TOKEN=
