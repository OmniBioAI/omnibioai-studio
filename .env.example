# ── Database ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=omnibioai
MYSQL_DEFAULT_DB=omnibioai

# ── Auth ──────────────────────────────────────────────────
AUTH_SECRET_KEY=change-me-in-production

# ── LIMS ──────────────────────────────────────────────────
LIMSX_DJANGO_SECRET_KEY=omnibioai-studio-secret

# ── Network ───────────────────────────────────────────────
HOST_IP=0.0.0.0

# ── Paths (absolute paths on host machine) ────────────────
# Directory containing MySQL init SQL scripts
DB_INIT_DIR=/path/to/omnibioai-studio/db-init

# Workspace directory for tools and runs
WORKSPACE_HOST=/path/to/workspace

# Working directory for run artifacts
WORK_DIR=/path/to/work

# Data directory for model registry, tool images etc.
DATA_DIR=/path/to/data

# Video files directory
VIDEO_DIR=/path/to/videos

# ── AI API Keys (optional) ────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Sentry Error Tracking ─────────────────────────────────
# Get free DSN at https://sentry.io (create 2 projects: Python + JavaScript)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT=beta
SENTRY_RELEASE=0.2.0-beta
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
VITE_SENTRY_ENVIRONMENT=beta
