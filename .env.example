# OmniBioAI Studio — copy to .env and fill in values
# cp .env.example .env

# ── Network ────────────────────────────────────────────
HOST_IP=0.0.0.0

# ── Paths (set to your machine paths) ──────────────────
MACHINE_DIR=/path/to/your/machine/dir
WORKSPACE_HOST=/path/to/omnibioai
WORK_DIR=/path/to/omnibioai
DATA_DIR=/path/to/data
DB_INIT_DIR=/path/to/db-init
VIDEO_DIR=/path/to/omnibioai-videos/content

# ── Database ───────────────────────────────────────────
# AUTO-GENERATED on first launch — do not share
MYSQL_ROOT_PASSWORD=change-me-in-production

# ── Auth ───────────────────────────────────────────────
# AUTO-GENERATED on first launch — do not share
AUTH_SECRET_KEY=change-me-in-production
# AUTO-GENERATED on first launch — do not share
LICENSE_SECRET=change-me-in-production

# ── LIMS ───────────────────────────────────────────────
LIMS_USERNAME=admin
LIMS_PASSWORD=change-me
LIMS_REFRESH_TOKEN=

# ── LLM / AI (optional) ────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
RAGBIO_API_KEY=

# ── Monitoring (optional) ──────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=1.0.0

# ── GitHub (for pulling private images) ────────────────
GHCR_PULL_TOKEN=
# AUTO-GENERATED on first launch — do not share
GF_ADMIN_PASSWORD=omnibioai

# ── IDE Services ───────────────────────────────────────
JUPYTER_TOKEN=omnibioai
RSTUDIO_PASSWORD=omnibioai
VSCODE_PASSWORD=omnibioai
