{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "OmniBioAI service metrics — health, request rate, latency, error rate",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "options": {
                "0": { "text": "DOWN", "color": "red"   },
                "1": { "text": "UP",   "color": "green" }
              },
              "type": "value"
            }
          ],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        { "expr": "up{job=\"omnibioai-workbench\"}",      "legendFormat": "workbench",      "refId": "A" },
        { "expr": "up{job=\"omnibioai-lims\"}",            "legendFormat": "lims",            "refId": "B" },
        { "expr": "up{job=\"omnibioai-rag\"}",             "legendFormat": "rag",             "refId": "C" },
        { "expr": "up{job=\"omnibioai-control-center\"}", "legendFormat": "control-center", "refId": "D" },
        { "expr": "up{job=\"omnibioai-auth\"}",            "legendFormat": "auth",            "refId": "E" },
        { "expr": "up{job=\"redis\"}",                     "legendFormat": "redis",           "refId": "F" },
        { "expr": "up{job=\"cadvisor\"}",                  "legendFormat": "cadvisor",        "refId": "G" }
      ],
      "title": "Service Health Overview",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{name=~\"omnibioai-studio-(workbench|lims|rag|auth-service|toolserver|tes)-1\"}[5m])) by (name)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Network Receive Rate per Service (bytes/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 3,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(container_network_receive_errors_total{name=~\"omnibioai-studio-.*-1\"}[5m])",
          "legendFormat": "rx errors {{name}}",
          "refId": "A"
        },
        {
          "expr": "rate(container_network_transmit_errors_total{name=~\"omnibioai-studio-.*-1\"}[5m])",
          "legendFormat": "tx errors {{name}}",
          "refId": "B"
        }
      ],
      "title": "Container Network Errors per Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "id": 4,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "scrape_duration_seconds{job=~\"omnibioai.*\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Prometheus Scrape Duration per Service (s)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 5,
      "title": "Container Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percent",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"omnibioai-studio-.*\"}[2m]) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Container CPU Usage %",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"omnibioai-studio-.*\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Container Memory Usage",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 8,
      "title": "Queue & Cache",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of tasks waiting in each Celery queue",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 9,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "redis_list_length{key=~\"celery.*\"}",
          "legendFormat": "{{key}}",
          "refId": "A"
        }
      ],
      "title": "Celery Queue Depth",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Memory Used" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "Memory Used",
          "refId": "A"
        },
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Connected Clients",
          "refId": "B"
        }
      ],
      "title": "Redis Health",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 11,
      "title": "AI & Security",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=\"omnibioai-studio-rag-1\"}[5m])",
          "legendFormat": "RAG rx bytes/s",
          "refId": "A"
        },
        {
          "expr": "rate(container_network_transmit_bytes_total{name=\"omnibioai-studio-rag-1\"}[5m])",
          "legendFormat": "RAG tx bytes/s",
          "refId": "B"
        }
      ],
      "title": "RAG Container Network IO (bytes/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 13,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "scrape_samples_scraped{job=\"omnibioai-auth\"}",
          "legendFormat": "auth samples scraped",
          "refId": "A"
        },
        {
          "expr": "scrape_samples_post_metric_relabeling{job=\"omnibioai-auth\"}",
          "legendFormat": "auth post-relabel",
          "refId": "B"
        }
      ],
      "title": "Auth Service Scrape Activity",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["omnibioai", "services"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "OmniBioAI Services",
  "uid": "omnibioai-services",
  "version": 1
}
