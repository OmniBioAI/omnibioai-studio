{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "OmniBioAI Platform Overview — HTTP metrics, latency, health across all services",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(django_http_requests_total_by_view_transport_method_total[5m])) by (job)",
          "legendFormat": "{{job}} req/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_request_duration_seconds_count[5m])) by (job)",
          "legendFormat": "{{job}} req/s (fastapi)",
          "refId": "B"
        }
      ],
      "title": "HTTP Request Rate per Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(django_http_responses_total_by_status_view_method_total{status=~\"5..\"}[5m])) by (job) / sum(rate(django_http_responses_total_by_status_view_method_total[5m])) by (job)",
          "legendFormat": "{{job}} 5xx rate",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_request_duration_seconds_count{status_code=~\"5..\"}[5m])) by (job) / sum(rate(http_request_duration_seconds_count[5m])) by (job)",
          "legendFormat": "{{job}} 5xx rate (fastapi)",
          "refId": "B"
        }
      ],
      "title": "HTTP Error Rate (5xx) per Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(django_http_requests_latency_seconds_by_view_method_bucket[5m])) by (le, job))",
          "legendFormat": "{{job}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(django_http_requests_latency_seconds_by_view_method_bucket[5m])) by (le, job))",
          "legendFormat": "{{job}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(django_http_requests_latency_seconds_by_view_method_bucket[5m])) by (le, job))",
          "legendFormat": "{{job}} p99",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, job))",
          "legendFormat": "{{job}} p50 (fastapi)",
          "refId": "D"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, job))",
          "legendFormat": "{{job}} p95 (fastapi)",
          "refId": "E"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, job))",
          "legendFormat": "{{job}} p99 (fastapi)",
          "refId": "F"
        }
      ],
      "title": "Request Latency p50 / p95 / p99 per Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(django_http_requests_total_by_view_transport_method_total) by (job)",
          "legendFormat": "{{job}} active",
          "refId": "A"
        }
      ],
      "title": "Active Connections (cumulative requests in flight proxy)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        { "expr": "up{job=\"omnibioai-lims\"}", "legendFormat": "lims", "refId": "A" },
        { "expr": "up{job=\"omnibioai-rag\"}", "legendFormat": "rag", "refId": "B" },
        { "expr": "up{job=\"omnibioai-control-center\"}", "legendFormat": "control-center", "refId": "C" },
        { "expr": "up{job=\"omnibioai-workbench\"}", "legendFormat": "workbench", "refId": "D" }
      ],
      "title": "Service Health Status",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["omnibioai", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "OmniBioAI Platform Overview",
  "uid": "omnibioai-platform-overview",
  "version": 1
}
